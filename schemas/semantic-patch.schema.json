{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jmxpls.dev/schemas/semantic-patch.schema.json",
  "title": "SemanticPatch",
  "type": "object",
  "required": ["operations"],
  "additionalProperties": false,
  "properties": {
    "dryRun": { "type": "boolean" },
    "validate": { "type": "boolean" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/addNode" },
          { "$ref": "#/$defs/updateField" },
          { "$ref": "#/$defs/deleteNode" },
          { "$ref": "#/$defs/moveNode" },
          { "$ref": "#/$defs/cloneNode" },
          { "$ref": "#/$defs/setEnabled" }
        ]
      }
    }
  },
  "$defs": {
    "base": {
      "type": "object",
      "properties": {
        "opId": { "type": "string" },
        "nodeId": { "type": "string" }
      }
    },
    "addNode": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "parentNodeId", "nodeType"],
          "properties": {
            "op": { "const": "addNode" },
            "parentNodeId": { "type": "string" },
            "index": { "type": "integer", "minimum": 0 },
            "nodeType": { "type": "string", "minLength": 1 },
            "fields": { "type": "object" }
          }
        }
      ]
    },
    "updateField": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "nodeId", "fieldPath", "value"],
          "properties": {
            "op": { "const": "updateField" },
            "nodeId": { "type": "string" },
            "fieldPath": { "type": "string", "minLength": 1 },
            "value": true
          }
        }
      ]
    },
    "deleteNode": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "nodeId"],
          "properties": {
            "op": { "const": "deleteNode" },
            "nodeId": { "type": "string" }
          }
        }
      ]
    },
    "moveNode": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "nodeId", "toParentNodeId"],
          "properties": {
            "op": { "const": "moveNode" },
            "nodeId": { "type": "string" },
            "toParentNodeId": { "type": "string" },
            "index": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "cloneNode": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "nodeId", "toParentNodeId"],
          "properties": {
            "op": { "const": "cloneNode" },
            "nodeId": { "type": "string" },
            "toParentNodeId": { "type": "string" },
            "index": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "setEnabled": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["op", "nodeId", "enabled"],
          "properties": {
            "op": { "const": "setEnabled" },
            "nodeId": { "type": "string" },
            "enabled": { "type": "boolean" }
          }
        }
      ]
    }
  }
}

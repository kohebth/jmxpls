{
  "name": "jmxpls",
  "version": "0.0.0",
  "private": true,
  "description": "JMeter Plan Language Server over MCP",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "bin": {
    "jmxpls": "bin/jmxpls"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "test:integration": "corepack pnpm -r test",
    "test:e2e": "cd packages/mcp-server && vitest run test/e2e/workflow.test.ts",
    "test:fuzz": "corepack pnpm -r test",
    "test:compatibility": "corepack pnpm -r test",
    "compatibility:report": "node scripts/render-compatibility-report.mjs",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "bridge:build": "cd packages/java-bridge && gradle build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "ajv": "^8.17.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
